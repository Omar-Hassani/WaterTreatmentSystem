@model WaterTreatmentSystem.Models.WaterQualityAnalysis
@{
    ViewData["Title"] = "إضافة فحص مخبري";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">

                <div class="mb-4 text-center">
                    <div class="icon-shape bg-soft-info text-info rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-clipboard2-pulse fs-3"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-1">تسجيل عينة فحص دورية</h2>
                    <p class="text-muted small">المحطة المستهدفة: <strong class="text-primary">@ViewBag.PlantName</strong></p>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                    <input type="hidden" asp-for="PlantId" />

                    <div class="row g-4">

                        <div class="col-12">
                            <label asp-for="AnalysisDate" class="form-label fw-semibold text-secondary">تاريخ ووقت التحليل المخبري</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-clock"></i></span>
                                <input asp-for="AnalysisDate" class="form-control bg-light border-start-0 rounded-end-3" type="datetime-local" />
                            </div>
                            <span asp-validation-for="AnalysisDate" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TdsInlet" class="form-label fw-semibold text-secondary">ملوحة مياه الدخول (TDS Inlet)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted">ppm</span>
                                <input asp-for="TdsInlet" class="form-control bg-light border-start-0 rounded-end-3" type="number" placeholder="مثال: 800" />
                            </div>
                            <span asp-validation-for="TdsInlet" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TdsOutlet" class="form-label fw-semibold text-secondary">ملوحة المياه المنتجة (TDS Outlet)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted">ppm</span>
                                <input asp-for="TdsOutlet" class="form-control bg-light border-start-0 rounded-end-3" type="number" placeholder="مثال: 35" />
                            </div>
                            <span asp-validation-for="TdsOutlet" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Ph" class="form-label fw-semibold text-secondary">درجة الحموضة القياسية (pH)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-reception-4"></i></span>
                                <input asp-for="Ph" class="form-control bg-light border-start-0 rounded-end-3" type="number" step="0.01" placeholder="مثال: 7.2" />
                            </div>
                            <span asp-validation-for="Ph" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Turbidity" class="form-label fw-semibold text-secondary">درجة العكارة الكلية (Turbidity)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted">NTU</span>
                                <input asp-for="Turbidity" class="form-control bg-light border-start-0 rounded-end-3" type="number" step="0.01" placeholder="مثال: 0.15" />
                            </div>
                            <span asp-validation-for="Turbidity" class="text-danger small mt-1 d-block"></span>
                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-5">
                        <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 flex-grow-1 fw-bold shadow-sm transition-smooth">
                            <i class="bi bi-calculator me-1"></i> احتساب النتائج وتوثيق العينة
                        </button>
                        <a asp-controller="Plants" asp-action="Details" asp-route-id="@Model.PlantId" class="btn btn-light rounded-pill px-4 py-2 fw-semibold border transition-smooth">
                            إلغاء والتراجع
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-info {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .transition-smooth {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
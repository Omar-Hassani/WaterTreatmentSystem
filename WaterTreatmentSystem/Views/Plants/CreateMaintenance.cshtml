@model WaterTreatmentSystem.Models.MaintenanceLog

@{
    ViewData["Title"] = "تدوين أمر صيانة جديد";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">

                <div class="mb-4 text-center">
                    <div class="icon-shape bg-soft-danger text-danger rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-wrench-adjustable fs-3"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-1">تدوين أمر صيانة فنية / وقائية</h2>
                    <p class="text-muted small">المحطة: <strong class="text-primary">@ViewBag.PlantName</strong></p>
                </div>

                <form asp-action="CreateMaintenance" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                    <input type="hidden" asp-for="PlantId" />

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="MaintenanceDate" class="form-label fw-semibold text-secondary">تاريخ تنفيذ الصيانة</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-calendar-event"></i></span>
                                <input asp-for="MaintenanceDate" class="form-control bg-light border-start-0 rounded-end-3" type="date" />
                            </div>
                            <span asp-validation-for="MaintenanceDate" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Cost" class="form-label fw-semibold text-secondary">التكلفة المالية الإجمالية</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-cash-coin"></i></span>
                                <input asp-for="Cost" class="form-control bg-light border-start-0 rounded-end-3" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Cost" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="TechnicianName" class="form-label fw-semibold text-secondary">المهندس / الفني المسؤول</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-person-gear"></i></span>
                                <input asp-for="TechnicianName" class="form-control bg-light border-start-0 rounded-end-3" placeholder="اسم منفذ الصيانة الفنية أو الخارجية" />
                            </div>
                            <span asp-validation-for="TechnicianName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold text-secondary">تفاصيل الخدمة والصيانة المنفذة</label>
                            <textarea asp-for="Description" class="form-control bg-light rounded-3" rows="4" placeholder="اكتب بالتفصيل الأعمال المنفذة (مثال: غسيل كيميائي للأغشية باستخدام حمض الستريك، تبديل فيوزات لوحة التحكم، تنظيف فلتر الرمل الرئيسي...)"></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-5">
                        <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 flex-grow-1 fw-bold shadow-sm">
                            <i class="bi bi-check-circle me-1"></i> حفظ وتثبيت أمر الصيانة
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.PlantId" class="btn btn-light rounded-pill px-4 py-2 fw-semibold border">
                            إلغاء والعودة
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-danger {
        background-color: rgba(220, 53, 69, 0.1);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
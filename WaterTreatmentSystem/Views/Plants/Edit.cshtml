@model WaterTreatmentSystem.Models.Plant

@{
    ViewData["Title"] = $"تعديل | {Model.Name}";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">

                <div class="mb-4 text-center">
                    <div class="icon-shape bg-soft-warning text-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-pencil-square fs-3"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-1">تعديل بيانات المحطة</h2>
                    <p class="text-muted small">تحديث المعايير الهندسية أو تغيير موقع المحطة الحالية</p>
                </div>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold text-secondary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-building"></i></span>
                                <input asp-for="Name" class="form-control bg-light border-start-0 rounded-end-3" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Location" class="form-label fw-semibold text-secondary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-geo-alt"></i></span>
                                <input asp-for="Location" class="form-control bg-light border-start-0 rounded-end-3" />
                            </div>
                            <span asp-validation-for="Location" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Capacity" class="form-label fw-semibold text-secondary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-speedometer2"></i></span>
                                <input asp-for="Capacity" class="form-control bg-light border-start-0 rounded-end-3" type="number" step="any" />
                            </div>
                            <span asp-validation-for="Capacity" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PlantType" class="form-label fw-semibold text-secondary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-gear"></i></span>
                                <select asp-for="PlantType" class="form-select bg-light border-start-0 rounded-end-3 text-dark fw-medium">
                                    <option value="RO">RO - تناضح عكسي</option>
                                    <option value="UF">UF - ترشيح فائق</option>
                                    <option value="Nano">NF - نانو فلترة</option>
                                </select>
                            </div>
                            <span asp-validation-for="PlantType" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="InstallationDate" class="form-label fw-semibold text-secondary"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3 text-muted"><i class="bi bi-calendar3"></i></span>
                                <input asp-for="InstallationDate" class="form-control bg-light border-start-0 rounded-end-3" type="date" />
                            </div>
                            <span asp-validation-for="InstallationDate" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-5">
                        <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 flex-grow-1 fw-bold shadow-sm transition-smooth">
                            <i class="bi bi-save me-1"></i> حفظ التعديلات
                        </button>
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 py-2 fw-semibold border transition-smooth">
                            إلغاء
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .transition-smooth {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}